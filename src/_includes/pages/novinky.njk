{% extends "layouts/base.njk" %}

{% block head %}
    <script defer src="/assets/js/search.js"></script>
{% endblock head %}

{% block body %}
    {% include "sections/landing.njk" %}

    <!-- BLOG POSTS -->
    <section class="~py-16/24 ~px-4/8">
        <div class="container m-auto flex flex-col ~gap-8/16">
            <!-- HEADING + SEARCH BAR -->
            <div class="flex justify-between items-end">
                <!-- TOPPER + HEADING -->
                <div class="flex flex-col items-start ~gap-3/4">
                    <span class="topper">{{ blog.topper }}</span>
                    <h2 class="~text-3xl/5xl text-black dark:text-white font-bold !leading-[1.1] tracking-wide">
                        {{ blog.heading }}
                    </h2>
                </div>

                <!-- SEARCH BAR -->
                <form role="search" method="GET" class="flex gap-1 w-full lg:max-w-[18rem]">
                    <label for="search-input" class="sr-only">Search</label>
                    <input
                        type="search"
                        id="search-input"
                        name="q"
                        placeholder="Hledat příspěvky"
                        autocomplete="off"
                        class="form-input w-full px-4 bg-white dark:bg-gray-950 text-sm text-gray-800 dark:text-gray-200 border-2 border-gray-200 dark:border-gray-800 rounded-full focus:border-gray-950/50 focus:ring-gray-950/25">
                </form>
            </div>

            <!-- NOVINKY -->
            <ul id="posts" class="grid grid-cols-3 gap-y-8 ~gap-x-4/6">
                {% for item in collections.novinky | reverse %}
                    {% include "components/novinky-item.njk" %}
                {% endfor %}
            </ul>
        </div>
    </section>

    {% include "sections/cta.njk" %}
{% endblock body %}