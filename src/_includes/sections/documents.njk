<!-- DOCUMENTS -->
<section id="dokumenty" class="peer ~py-16/24 ~px-4/8 bg-slate-100 dark:bg-slate-900">
    <div class="container m-auto flex flex-col ~gap-12/16">
        <!-- TOPPER + HEADING -->
        <div class="flex flex-col items-start ~gap-3/4">
            <span class="topper">{{ documents.topper }}</span>
            <h2 class="~text-3xl/5xl text-black dark:text-white font-bold !leading-[1.1] tracking-wide">
                {{ documents.heading }}
            </h2>
        </div>

        <!-- ITEMS -->
        <ul class="grid grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 ~gap-4/6">
            {% for document in items %}
                {% include "components/document-item.njk" %}
            {% endfor %}
        </ul>
    </div>
</section>