<!-- FOOTER -->
<footer class="~py-12/24 ~px-4/8 bg-slate-950">
    <div class="container m-auto flex flex-col gap-16">
        <!-- LOGO + CONTACT -->
        <div class="flex flex-col xl:flex-row justify-between items-start gap-12">
            <!-- LOGO + NAVIGATION -->
            <div class="flex flex-col items-start ~gap-12/20">
                <!-- LOGO + DESCRIPTION -->
                <div class="flex flex-col items-start ~gap-6/8">
                    <!-- LOGO -->
                    <div class="flex items-center ~gap-4/7">
                        <img
                            class="~h-16/24 w-auto"
                            src="/assets/svgs/logo-symbol-white.svg"
                            alt="{{ client.name }} - světlé logo"
                            width="64"
                            height="64"
                            loading="lazy"
                            decoding="async"
                            aria-hidden="true"
                            draggable="false">

                        <span class="~max-w-44/72 text-white ~text-[1.125rem]/[1.75rem] font-bold ~leading-[1.5rem]/[2rem]">{{ client.name }}</span>
                    </div>

                    <p class="~max-w-sm/md font-inter ~text-base/lg text-slate-200">{{ footer.description | safe }}</p>
                </div>

                <!-- NAVIGATION -->
                <nav class="hidden sm:block">
                    <ul class="flex flex-wrap gap-y-4 gap-x-8">
                        {% for item in footer.navigation %}
                            <li>
                                <a
                                    href="{{ item.url }}"
                                    class="relative font-inter text-slate-200 aria-[current=page]:text-white aria-[current=page]:font-medium before:absolute before:-bottom-1 before:left-0 before:h-px before:w-full before:bg-slate-200 before:transition-transform before:duration-300 before:scale-x-0 hover:before:scale-x-100"
                                    {%- if item.url == page.url -%} aria-current="page" {% endif -%}>
                                    {{ item.text }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </nav>
            </div>

            <!-- CONTACTS -->
            <ul class="flex ~gap-12/32">
                {% for item in footer.contacts %}
                    <li class="flex flex-col ~gap-1/2">
                        <span class="~text-base/xl text-slate-300 font-medium">{{ item.title }}</span>

                        {% if item.url %}
                            <a href="{{ item.url }}" class="~text-lg/2xl text-white font-semibold">{{ item.text }}</a>
                        {% else %}
                            <span class="~text-lg/2xl text-white font-semibold">{{ item.text }}</span>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>

        <!-- SEPARATOR + COPYRIGHT -->
        <div class="flex flex-col gap-6">
            <div class="h-px bg-slate-800"></div>

            <!-- COPYRIGHT + GDPR -->
            <div class="flex flex-col md:flex-row items-center justify-between gap-2">
                <p class="font-inter text-center sm:text-left text-sm text-slate-400">
                    {{ footer.copyright }}
                    <a href="{{ footer.copyrightLink.url }}" target="_blank" class="underline hover:text-white">{{ footer.copyrightLink.text }}</a>
                </p>

                <a href="{{ footer.gdprLink.url }}" class="font-inter text-center sm:text-right text-sm text-slate-400 hover:underline hover:text-white">{{ footer.gdprLink.text }}</a>
            </div>
        </div>
    </div>
</footer>